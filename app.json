{
  "expo": {
    "name": "Citadel",
    "slug": "citadel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D0C11"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.citadel",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow Citadel to access your camera to take profile photos and scan notes.",
        "NSPhotoLibraryUsageDescription": "Allow Citadel to access your photos for profile and class images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D0C11"
      },
      "package": "app.citadel",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Citadel to access your photos for profile and class images.",
          "cameraPermission": "Allow Citadel to access your camera to take profile photos and scan notes."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "9871221b-3c55-4364-81c0-28793224b33d"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9871221b-3c55-4364-81c0-28793224b33d"
    }
  }
}
